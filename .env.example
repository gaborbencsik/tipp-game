# Backend
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://tipp_user:tipp_pass@localhost:5432/tipp_game

# Supabase (prod/staging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

ADMIN_EMAILS=admin@dev.local

# CORS
CORS_ORIGIN=http://localhost:5173

# Internal sync service token (used by Render cron jobs to call /api/internal/sync/*)
# Generate: `openssl rand -hex 32` (32 byte / 64 hex char). The same value MUST be set
# on the backend web service AND on each cron service in Render.
SYNC_SERVICE_TOKEN=replace-me-with-random-secret

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5173

# Frontend (Vite) env vars
VITE_DEV_AUTH_BYPASS=true
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_API_URL=http://localhost:3000

# Football API (api-football.com / api-sports.io)
# Ingyenes key: https://dashboard.api-football.com/register
# Free tier: 100 req/nap (elegendő fejlesztéshez és NB II teszteléshez)
# Pro tier ($19/hó): 7500 req/nap (szükséges VB 2026 live meccsekhez)
FOOTBALL_API_KEY=your_api_sports_key_here
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# Liga ID-k – verifikáld: GET /leagues?country=Hungary
FOOTBALL_API_WC_LEAGUE_ID=1
FOOTBALL_API_NBI_LEAGUE_ID=271
FOOTBALL_API_NBII_LEAGUE_ID=272
# Pre-VB barátságos válogatott meccsek (api-football: "Friendlies: International")
FOOTBALL_API_FRIENDLY_LEAGUE_ID=10

# Match Pulse raw stats lekérési mód
# - false (alapértelmezett): csapatonként 3 hívás (2024, 2025, 2026 szezon)
# - true: csapatonként 1 hívás `from`/`to` (utolsó 24 hónap) paraméterekkel
# Az új mód kb. 3x kevesebb API hívást igényel, így ritkábban ütközik rate limitbe.
INSIGHT_RAW_STATS_USE_DATE_RANGE=false

# Szinkronizációs mód (off | final_only | adaptive | full_live)
# Alapértelmezett: adaptive
# - off:         nincs API hívás (fejlesztés, CI, API key nélküli local dev)
# - final_only:  csak végeredmény lekérés meccs után, nincs live követés (~20-40 req/nap)
# - adaptive:    live meccs alatt 2 percenként, egyébként ritka napi sync (~100-300 req/nap)
# - full_live:   minden percben live lekérdezés, legkisebb latencia (max kvóta, Pro tier kell)
FOOTBALL_SYNC_MODE=final_only

# Belső league UUID-k (a leagues tábla id-jai — sync route-nak kell az API ↔ DB összerendeléshez)
# Ezeket a DB-ből kell kiolvasni: SELECT id, short_name FROM leagues;
# A Pre-VB liga UUID-okat (PRE-VB-1/2/3) NEM kell env-be állítani: a sync futási időben
# a 0032 migráció által létrehozott rekordokat short_name alapján olvassa ki a DB-ből.
FOOTBALL_INTERNAL_WC_LEAGUE_ID=
FOOTBALL_INTERNAL_NBI_LEAGUE_ID=

# Gemini (US-1302 Match Pulse insight generator)
# Ingyenes key: https://aistudio.google.com/apikey
# Free tier: 500 RPD / 15 RPM (Gemini Flash-Lite)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Donation (Revolut) — ha hiányzik, a gomb rejtve marad
# VITE_DONATION_URL: Revolut.me URL template ({currency} és {amount} placeholder-ekkel)
VITE_DONATION_URL=https://revolut.me/gaborbencsik?currency={currency}&amount={amount}&note={note}

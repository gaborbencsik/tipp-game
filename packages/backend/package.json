{
  "name": "@tipp-game/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "migrate:prod": "node dist/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed-local": "tsx scripts/seed-local.ts"
  },
  "dependencies": {
    "@google/genai": "2.6.0",
    "@koa/cors": "5.0.0",
    "@koa/router": "13.1.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/web-push": "3.6.4",
    "drizzle-orm": "0.44.7",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "koa": "3.2.0",
    "koa-bodyparser": "4.4.1",
    "koa-compress": "5.2.1",
    "koa-helmet": "7.1.0",
    "pg": "8.20.0",
    "ua-parser-js": "2.0.10",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/koa": "2.15.0",
    "@types/koa__cors": "5.0.1",
    "@types/koa__router": "12.0.5",
    "@types/koa-bodyparser": "4.3.13",
    "@types/koa-compress": "4.0.7",
    "@types/node": "22.19.15",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-istanbul": "3.2.4",
    "drizzle-kit": "0.31.10",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
